<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background -->
    <ImageView
        android:id="@+id/catImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/cat_image" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="16dp">

            <DatePicker
                android:id="@+id/datePicker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#A6FFFFFF"
                android:calendarViewShown="false"
                android:datePickerMode="spinner" />

            <TextView
                android:id="@+id/tvNoJournal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No journal entry for this date."
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:layout_marginTop="20dp"
                android:textStyle="italic"
                android:background="#80000000"
                android:padding="8dp"/>

            <!-- Preview Card -->
            <LinearLayout
                android:id="@+id/previewLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#D9FFFFFF"
                android:padding="16dp"
                android:layout_marginTop="20dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvTitlePreview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="😊 Title"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#4A2E2A"/>

                <TextView
                    android:id="@+id/tvContentPreview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Content snippet..."
                    android:textSize="16sp"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnOpenJournal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OPEN JOURNAL"
                android:layout_marginTop="20dp"
                android:backgroundTint="#F58B7A"
                android:textColor="@android:color/white"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
